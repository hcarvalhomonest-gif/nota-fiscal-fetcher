# URL base das edge functions do NotaSync (Lovable Cloud)
# Formato: https://<project-ref>.supabase.co/functions/v1
SUPABASE_FUNCTIONS_URL=https://cwxsalprevqrtimkgxwo.supabase.co/functions/v1

# Mesmo segredo cadastrado no Lovable Cloud em
# Cloud > Settings > Edge Function Secrets > WORKER_SHARED_SECRET
WORKER_SHARED_SECRET=cole-aqui-o-mesmo-segredo

# Ambiente do Sistema Nacional NFS-e (ADN)
# Produção:    https://adn.nfse.gov.br
# Homologação: https://adn.producaorestrita.nfse.gov.br
NFSE_BASE_URL=https://adn.nfse.gov.br

# Intervalo (ms) de polling para pegar o próximo job
POLL_INTERVAL_MS=10000

# Limite de páginas (NSU) por job — segurança contra loop infinito
MAX_PAGES=1000

# Pequena pausa entre requisições para não tomar HTTP 429 do ADN
REQUEST_DELAY_MS=250
