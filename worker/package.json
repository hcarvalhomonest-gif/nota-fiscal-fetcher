{
  "name": "notasync-worker",
  "version": "1.0.0",
  "description": "Worker que conecta ao portal nacional NFS-e (gov.br) via mTLS com certificado A1, baixa XMLs e PDFs e devolve para a API do NotaSync (Lovable Cloud).",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc"
  },
  "dependencies": {
    "node-forge": "^1.3.1",
    "undici": "^6.19.8",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "@types/node-forge": "^1.3.11"
  }
}
